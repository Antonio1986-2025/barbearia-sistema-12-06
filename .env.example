# ─────────────────────────────────────────────────────────────
# Barbearia Status — variáveis de ambiente
# Copie este arquivo para .env e preencha com os valores do seu
# projeto Supabase. NUNCA versione o .env (ele contém segredos).
# ─────────────────────────────────────────────────────────────

# === SUPABASE ===
# URL do projeto Supabase (ex.: https://xxxxxxxx.supabase.co)
SUPABASE_URL="https://SEU_PROJETO.supabase.co"
VITE_SUPABASE_URL="https://SEU_PROJETO.supabase.co"

# Chave pública (anon / publishable) — pode ser exposta ao navegador
SUPABASE_PUBLISHABLE_KEY="sua-chave-anon-publica"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-chave-anon-publica"

# ID do projeto (opcional, usado por algumas ferramentas)
VITE_SUPABASE_PROJECT_ID="seu-project-id"

# Chave de serviço (service_role) — SECRETA, apenas no servidor.
# NUNCA use o prefixo VITE_ nesta chave (ela não pode ir para o navegador).
# Obtenha em: Supabase > Project Settings > API > service_role.
SUPABASE_SERVICE_ROLE_KEY="sua-chave-service-role-secreta"

# URL pública de agendamento usada pela IA do WhatsApp (Edge Function).
# Em produção, aponte para o domínio próprio (ex.: https://suabarbearia.com/agendar).
PUBLIC_BOOKING_URL="http://localhost:3000/agendar"

# === AGENTE DE IA (WHATSAPP) ===
# OpenAI API Key para o agente conversacional
OPENAI_API_KEY="sua-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"

# Evolution API - Gerenciador de WhatsApp
EVOLUTION_URL="https://sua-evolution-api.com"
EVOLUTION_API_KEY="sua-evolution-api-key"
EVOLUTION_INSTANCE="nome-da-instancia"

# Porta do servidor do agente de IA (webhook)
AI_PORT="3001"

# Secret para validar webhooks (opcional mas recomendado)
WEBHOOK_SECRET="seu-secret-aleatorio"
